{
  "name": "tingatalk-backend",
  "version": "2.0.0",
  "type": "module",
  "description": "Backend server for TingaTalk video calling app",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "prod": "NODE_ENV=production node src/server.js",
    "build": "node --check src/server.js && node --check src/app.js && echo 'Build check passed'",
    "test": "vitest run",
    "test:watch": "vitest",
    "swagger:export": "node scripts/export-swagger.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop tingatalk-backend",
    "pm2:restart": "pm2 restart tingatalk-backend",
    "pm2:delete": "pm2 delete tingatalk-backend",
    "pm2:logs": "pm2 logs tingatalk-backend",
    "pm2:status": "pm2 status"
  },
  "keywords": [
    "twilio",
    "video",
    "calling",
    "websocket",
    "flutter"
  ],
  "author": "TingaTalk Team",
  "license": "MIT",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^13.6.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.8.2",
    "js-yaml": "^4.1.0",
    "razorpay": "^2.9.3",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^4.19.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
